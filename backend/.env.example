# Copie este arquivo para .env e preencha os valores

# Banco de dados (Railway fornece automaticamente em produção)
DATABASE_URL=postgresql://user:password@localhost:5432/laco

# Servidor
PORT=3000
NODE_ENV=development

# Segurança — troque por uma string longa e aleatória
API_SECRET=troque-por-um-segredo-longo-aqui

# CORS — domínio do frontend em produção
FRONTEND_URL=http://localhost:8080

# Clínica (slug único usado na URL do portal do cliente)
CLINIC_SLUG=bella-estetica
CLINIC_NAME=Clínica Bella Estética

# Backup automático
BACKUP_DIR=./backups   # pasta para salvar os backups
BACKUP_KEEP=7          # quantos backups manter
